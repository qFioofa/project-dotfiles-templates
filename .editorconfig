root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitesapce = true

[*.kt]
indent_style = tab
indent_size = 4
tab_width = 4

[*.xml]
indent_style = tab
indent_size = 4

[*.gradle]
indent_style = tab
indent_size = 4

[*.java]
indent_style = tab
indent_size = 4
